{
  "name": "mart-pos",
  "private": false,
  "version": "1.4.1",
  "description": "A modern admin dashboard built with React, TypeScript, and Electron",
  "author": "NOMANAZHAR",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "dev:electron": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "knip": "knip",
    "e": "electron main.cjs",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "start:forge": "electron-forge start",
    "clean": "rimraf out dist dist-forge",
   "rebuild": "npx @electron/rebuild -f -w better-sqlite3 --electron-version=26.6.10 --module-dir=node_modules/better-sqlite3 --verbose"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-collapsible": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.7",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@standard-schema/utils": "^0.3.0",
    "@tabler/icons-react": "^3.34.0",
    "@tailwindcss/vite": "^4.1.10",
    "@tanstack/react-query": "^5.81.2",
    "@tanstack/react-router": "^1.121.34",
    "@tanstack/react-table": "^8.21.3",
    "@types/file-saver": "^2.0.7",
    "axios": "^1.10.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1",
    "file-saver": "^2.0.5",
    "input-otp": "^1.4.2",
    "js-cookie": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.523.0",
    "node-cache": "^5.1.2",
    "react": "^19.1.0",
    "react-day-picker": "9.7.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.58.1",
    "react-router": "^7.6.2",
    "react-router-dom": "^7.6.2",
    "react-top-loading-bar": "^3.0.2",
    "react-window": "^1.8.11",
    "recharts": "^3.0.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.10",
    "tw-animate-css": "^1.3.4",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5",
    "zod": "^3.25.67",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.8.3",
    "@electron-forge/maker-deb": "^7.8.3",
    "@electron-forge/maker-rpm": "^7.8.3",
    "@electron-forge/maker-squirrel": "^7.8.3",
    "@electron-forge/maker-zip": "^7.8.3",
    "@electron-forge/plugin-auto-unpack-natives": "^7.8.3",
    "@electron-forge/plugin-fuses": "^7.8.3",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^9.29.0",
    "@faker-js/faker": "^9.8.0",
    "@tanstack/eslint-plugin-query": "^5.81.2",
    "@tanstack/react-query-devtools": "^5.81.2",
    "@tanstack/react-router-devtools": "^1.121.34",
    "@tanstack/router-plugin": "^1.121.34",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/axios": "^0.14.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/cacheable-request": "^8.3.6",
    "@types/d3-array": "^3.2.2",
    "@types/d3-color": "^3.1.3",
    "@types/d3-ease": "^3.0.2",
    "@types/d3-interpolate": "^3.0.4",
    "@types/d3-path": "^3.1.1",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.7",
    "@types/d3-time": "^3.0.4",
    "@types/d3-timer": "^3.0.2",
    "@types/estree": "^1.0.8",
    "@types/fs-extra": "^11.0.4",
    "@types/http-cache-semantics": "^4.0.4",
    "@types/js-cookie": "^3.0.6",
    "@types/json-schema": "^7.0.15",
    "@types/keyv": "^4.2.0",
    "@types/mute-stream": "^0.0.4",
    "@types/node": "^24.8.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-window": "^1.8.8",
    "@types/responselike": "^1.0.3",
    "@types/use-sync-external-store": "^1.5.0",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "knip": "^5.61.2",
    "prettier": "^3.6.0",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "rimraf": "^6.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.0",
    "vite": "^7.0.0",
    "wait-on": "^7.2.0",
    "yargs": "17.7.2",
   "electron": "^26.6.10"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "build": {
    "appId": "com.shadcn.admin",
    "productName": "MartPOS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs",
      "electron-db.cjs",
      "sync-service.cjs",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "extraResources": [],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/images/shadcn-admin.png",
      "forceCodeSigning": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "public/images/shadcn-admin.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/images/shadcn-admin.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "menuCategory": "Business",
      "shortcutName": "MartPOS"
    }
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "icon": "public/images/shadcn-admin.png",
        "asar": true,
        "out": "dist-forge"
      },
      "makers": [
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "win32",
            "darwin",
            "linux"
          ]
        },
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "name": "MartPOS",
            "setupExe": "MartPOS-Setup.exe"
          }
        }
      ],
      "interactive": false
    }
  }

}
